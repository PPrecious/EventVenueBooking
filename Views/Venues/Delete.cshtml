@model EventVenueBooking.Models.Venue

@{
    ViewData["Title"] = "Delete Venue";
}

<h2>Delete Venue</h2>

<h4>Are you sure you want to delete this venue?</h4>

<div>
    <h5>@Model.VenueName</h5>
    <p><strong>Location:</strong> @Model.Location</p>
    <p><strong>Capacity:</strong> @Model.Capacity</p>
    <img src="@Model.ImageUrl" alt="@Model.VenueName" width="150" />
</div>

<form asp-action="DeleteConfirmed" method="post">
    <input type="hidden" asp-for="VenueId" />
    <button type="submit" class="btn btn-danger mt-2">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-secondary mt-2">Cancel</a>
</form>