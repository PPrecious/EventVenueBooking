@model EventVenueBooking.Models.Venue

@{
    ViewData["Title"] = "Venue Details";
}

<h2>Venue Details</h2>

<div class="card" style="width: 30rem;">
    <img class="card-img-top" src="@Model.ImageUrl" alt="@Model.VenueName">
    <div class="card-body">
        <h5 class="card-title">@Model.VenueName</h5>
        <p class="card-text"><strong>Location:</strong> @Model.Location</p>
        <p class="card-text"><strong>Capacity:</strong> @Model.Capacity</p>
        <a asp-action="Edit" asp-route-id="@Model.VenueId" class="btn btn-warning">Edit</a>
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</div>