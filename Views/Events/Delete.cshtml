@model EventVenueBooking.Models.Event

@{
    ViewData["Title"] = "Delete Event";
}

<h1>Delete Event</h1>

<h3>Are you sure you want to delete this event?</h3>

<div class="card">
    <div class="card-body">
        <h4 class="card-title">@Model.EventName</h4>
        <p><strong>Date:</strong> @Model.EventDate.ToString("yyyy-MM-dd")</p>
        <p><strong>Venue:</strong> @Model.Venue?.VenueName</p>
        <p><strong>Description:</strong> @Model.Description</p>
    </div>
</div>

<form asp-action="DeleteConfirmed" method="post">
    <input type="hidden" asp-for="EventId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>