@model EventVenueBooking.Models.ViewModels.DashboardViewModel

<h1>Dashboard</h1>

<div class="row">
    <div class="col-md-4">
        <div class="card p-3 mb-3 bg-primary text-white">
            <h4>Total Venues</h4>
            <h2>@Model.TotalVenues</h2>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-3 mb-3 bg-success text-white">
            <h4>Total Events</h4>
            <h2>@Model.TotalEvents</h2>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card p-3 mb-3 bg-warning text-dark">
            <h4>Total Bookings</h4>
            <h2>@Model.TotalBookings</h2>
        </div>
    </div>
</div>